# Local Postgres often uses your current OS/db role. If needed, set an explicit user such as:
# DATABASE_URL=postgresql+psycopg://chas@localhost:5432/scheduler
DATABASE_URL=postgresql+psycopg://localhost:5432/scheduler
PARSER_MODE=stub
# PARSER_MODE=groq
FEATHER_API_KEY=
GROQ_API_KEY=
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8000
# Required for Google OAuth. Set a strong random secret.
OAUTH_STATE_SECRET=replace-me-with-a-random-secret
# Required for Google OAuth. If unset, the app shows:
# "OAuth not configured - set env vars"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google/oauth/callback
